builddir = build

includes = -Iinclude -Ikernel/include -Ikernel -Ikernel/include -Iarch/x86_64/include -Ilib/libc/include -Iapi
cflags = -m64 -mcmodel=large -ffreestanding -fno-pic -nostdlib -nostartfiles -nodefaultlibs
asflags = -f elf64

rule cc
  command = gcc $cflags $includes -c $in -o $out
  description = CC $in

rule cc_boot
  command = gcc $cflags $includes -c $in -o $out
  description = CC_BOOT $in

rule nasm
  command = nasm $asflags -o $out $in
  description = NASM $in

rule ld
  command = ld -T d:/Kenux kernel/kernel/arch/x86_64/boot/linker.ld -o $out $in
  description = LD $out

build build/boot.o: nasm arch/x86_64/boot/boot.S
build build/interrupt_asm.o: nasm arch/x86_64/interrupt.S
build build/api/kapi_device.o: cc api/kapi_device.c
build build/api/kapi_fs.o: cc api/kapi_fs.c
build build/api/kapi_init.o: cc api/kapi_init.c
build build/api/kapi_memory.o: cc api/kapi_memory.c
build build/api/kapi_process.o: cc api/kapi_process.c
build build/api/kapi_syscall.o: cc api/kapi_syscall.c
build build/arch_x86_64/ac97.o: cc arch/x86_64/ac97.c
build build/arch_x86_64/acpi.o: cc arch/x86_64/acpi.c
build build/arch_x86_64/acpi_madt.o: cc arch/x86_64/acpi_madt.c
